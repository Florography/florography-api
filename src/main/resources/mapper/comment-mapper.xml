<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace= "com.korit.florographyapi.ShareBoard.mapper.CommentMapper" >

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into comment values
        (default, #{boardId}, #{userId}, #{body}, #{createdAt})
    </insert>
    <select id="selectByBoardId" resultType="com.korit.florographyapi.entity.Comment">
        select
            id,
            board_id,
            user_id,
            body,
            created_at
        from
            comment
        where
            board_id = #{boardId}
        order by
            created_at desc
    </select>

    <update id="update">
        update
            comment
        set
            body = #{body}
        where
            id = #{id}
        and
            user_id = #{userId}
    </update>

    <delete id="delete">
        delete
        from
            comment
        where
            id = #{id}
        and
            board_id = #{boardId}
        and
            user_id = #{userId}
    </delete>

</mapper>