<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.korit.florographyapi.comment.mapper.CommentMapper">

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into comment values
        (default, #{userId}, #{body}, #{createdAt})
    </insert>

    <update id="update">
        update
            comment
        set
            body = #{body}
        where
            user_id = #{userId}
            and created_at = #{createdAt}
    </update>

    <select id="selectAllComment" resultType="com.korit.florographyapi.entity.Comment">
        select
            id,
            user_id,
            body,
            created_at
        from
            comment
        order by
            created_at desc
    </select>
</mapper>