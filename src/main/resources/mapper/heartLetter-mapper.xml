<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace= "com.korit.florographyapi.HeartLetter.mapper.HeartLetterMapper" >

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into heart_letter values
        (default, #{userId}, #{title}, #{recipient}, #{body}, #{paperTheme}, #{fontSize}, #{moodIdx}, #{createdAt})
    </insert>
    <update id="update">
        update
            heart_letter
        set
            title = #{title},
            recipient = #{recipient},
            body = #{body},
            paper_theme = #{paperTheme},
            font_size = #{fontSize},
            mood_idx = #{moodIdx}
        where
            id = #{id}
        and
            user_id = #{userId}
    </update>
    <select id="selectAllUserId" resultType="com.korit.florographyapi.entity.HeartLetter">
        select
            id,
            user_id,
            title,
            recipient,
            body,
            paper_theme,
            font_size,
            mood_idx,
            created_at
        from
            heart_letter
        where
            user_id = #{userId}
    </select>
    <select id="selectByUserId" resultType="com.korit.florographyapi.entity.HeartLetter">
        select
            id,
            user_id,
            title,
            recipient,
            body,
            paper_theme,
            font_size,
            mood_idx,
            created_at
        from
            heart_letter
        where
            user_id = #{userId}
    </select>

</mapper>